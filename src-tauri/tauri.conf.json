{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Passero",
  "version": "0.0.0",
  "identifier": "com.fredsmith.passero",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Passero",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "theme": "Dark",
        "titleBarStyle": "Overlay"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
